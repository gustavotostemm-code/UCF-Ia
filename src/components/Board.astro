---
const base = import.meta.env.BASE_URL;
const boardMembers = [
  {
    role: "President",
    name: "Victoria Bressan",
    major: "Computer Engineering",
    linkedin: "https://www.linkedin.com/in/victoria-bressan/",
    photo: `${base}victoria.png`
  },
  {
    role: "Vice-President",
    name: "Gustavo Toste",
    major: "Computer Engineering",
    linkedin: "https://www.linkedin.com/in/gustavo-toste-de-castro-340640382/?skipRedirect=true",
    photo: `${base}gustavo.png`
  },
  {
    role: "Treasurer",
    name: "Alex Johnson",
    major: "Computer Science",
    linkedin: "#",
    photo: null
  },
  {
    role: "Secretary",
    name: "Maria Silva",
    major: "Computer Engineering",
    linkedin: "#",
    photo: null
  },
  {
    role: "Tech Lead",
    name: "David Chen",
    major: "Computer Science",
    linkedin: "#",
    photo: null
  }
];
---

<section id="board">
  <div class="container">
    <h2 class="section-title" style="text-align:center;">EXECUTIVE BOARD</h2>
    <p class="board-year">2025-2026</p>

    <div class="board-grid">
      {boardMembers.map((member) => (
        <div class="member-card card">
          <a href={member.linkedin} target="_blank" class="linkedin-icon" aria-label="LinkedIn">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>

          <div class="member-avatar">
            {member.photo
              ? <img src={member.photo} alt={member.name} />
              : <span class="member-initials">{member.name.split(' ').map((n: string) => n[0]).join('')}</span>
            }
          </div>

          <div class="member-info">
            <p class="member-role">{member.role}</p>
            <span class="member-name tag">{member.name}</span>
            <span class="member-major">{member.major}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  #board {
    padding: 4rem 0;
  }

  .board-year {
    text-align: center;
    color: var(--text-muted);
    font-size: 0.9rem;
    margin-bottom: 3rem;
  }

  .board-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1.5rem;
    justify-items: center;
  }

  .member-card {
    width: 100%;
    max-width: 220px;
    position: relative;
    padding: 1.5rem 1rem 1rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    text-align: center;
    transition: transform 0.2s, box-shadow 0.2s;
    border: 1px solid var(--border);
  }

  .member-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 30px rgba(240,180,41,0.12);
  }

  .linkedin-icon {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    color: #0077b5;
    transition: opacity 0.2s;
    opacity: 0.8;
  }
  .linkedin-icon:hover { opacity: 1; }

  .member-avatar {
    width: 120px;
    height: 120px;
    border-radius: 12px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 2px solid var(--border);
    background: linear-gradient(135deg, #1e1e1e, #2d2d2d);
  }

  .member-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }

  .member-initials {
    font-family: var(--font-display);
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--gold);
  }

  .member-info {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
  }

  .member-role {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    color: var(--gold);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .member-name {
    font-size: 0.8rem;
    background: var(--gold);
    color: #000;
    font-weight: 700;
  }

  .member-major {
    font-size: 0.75rem;
    color: var(--text-muted);
    border: 1px solid #444;
    border-radius: 999px;
    padding: 0.15rem 0.6rem;
  }
</style>