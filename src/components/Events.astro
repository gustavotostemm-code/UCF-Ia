---

<section id="events">
  <div class="container">
    <!-- Upcoming Event -->
    <div class="upcoming">
      <h2 class="section-title" style="text-align:center;">UPCOMING EVENT</h2>

      <div class="event-card card">
        <h3 class="event-name">GBM #44</h3>
        <p class="event-location">HEC 116 – 11/01 @6pm</p>

        <div class="countdown" id="countdown">
          <div class="countdown-block">
            <span class="count-num" id="days">00</span>
            <span class="count-label">DAYS</span>
          </div>
          <div class="countdown-block">
            <span class="count-num" id="hours">00</span>
            <span class="count-label">HOURS</span>
          </div>
          <div class="countdown-block">
            <span class="count-num" id="minutes">00</span>
            <span class="count-label">MINUTES</span>
          </div>
        </div>

        <a href="#" class="more-info">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
          </svg>
          more information
        </a>
      </div>
    </div>

    <!-- Past Events -->
    <div class="past-events">
      <h2 class="section-title" style="text-align:center;">PAST EVENTS</h2>

      <div class="carousel-wrapper card">
        <button class="carousel-btn prev" id="prevBtn" aria-label="Previous">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <polyline points="15 18 9 12 15 6"/>
          </svg>
        </button>

        <div class="carousel-inner">
          <div class="carousel-slide active">
            <h3 class="past-event-name">GBM #43</h3>
            <div class="past-event-images">
              <div class="img-placeholder img-1">
                <span>UCF AI DAY</span>
              </div>
              <div class="img-placeholder img-2">
                <span>Workshop</span>
              </div>
            </div>
          </div>
          <div class="carousel-slide">
            <h3 class="past-event-name">GBM #42</h3>
            <div class="past-event-images">
              <div class="img-placeholder img-3">
                <span>Hackathon</span>
              </div>
              <div class="img-placeholder img-4">
                <span>Networking</span>
              </div>
            </div>
          </div>
          <div class="carousel-slide">
            <h3 class="past-event-name">GBM #41</h3>
            <div class="past-event-images">
              <div class="img-placeholder img-5">
                <span>Guest Speaker</span>
              </div>
              <div class="img-placeholder img-6">
                <span>Project Demo</span>
              </div>
            </div>
          </div>
        </div>

        <button class="carousel-btn next" id="nextBtn" aria-label="Next">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <polyline points="9 18 15 12 9 6"/>
          </svg>
        </button>

        <div class="carousel-dots" id="carouselDots"></div>

        <a href="#" class="more-info">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
          </svg>
          more information
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  #events {
    padding: 4rem 0;
  }

  .upcoming, .past-events {
    margin-bottom: 4rem;
  }

  .event-card {
    max-width: 500px;
    margin: 2rem auto 0;
    text-align: center;
    border: 1px solid var(--border);
    background: rgba(30, 30, 30, 0.8);
    padding: 2.5rem 2rem;
  }

  .event-name {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 700;
    color: var(--gold);
    margin-bottom: 0.4rem;
  }

  .event-location {
    color: var(--gold);
    font-size: 0.85rem;
    margin-bottom: 2rem;
    opacity: 0.8;
  }

  .countdown {
    display: flex;
    gap: 1rem;
    justify-content: center;
    margin-bottom: 2rem;
  }

  .countdown-block {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;
    background: #111;
    border-radius: 8px;
    padding: 1rem 1.5rem;
    min-width: 80px;
  }

  .count-num {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 700;
    color: var(--text);
    line-height: 1;
  }

  .count-label {
    font-size: 0.65rem;
    color: var(--text-muted);
    letter-spacing: 0.1em;
  }

  .more-info {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--text-muted);
    font-size: 0.85rem;
    text-decoration: none;
    transition: color 0.2s;
    font-style: italic;
  }
  .more-info:hover { color: var(--gold); }

  /* Carousel */
  .carousel-wrapper {
    max-width: 600px;
    margin: 2rem auto 0;
    background: rgba(30, 30, 30, 0.8);
    border: 1px solid var(--border);
    padding: 2rem;
    position: relative;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .carousel-inner {
    width: 100%;
    overflow: hidden;
    position: relative;
  }

  .carousel-slide {
    display: none;
  }
  .carousel-slide.active { display: block; }

  .past-event-name {
    font-family: var(--font-display);
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--gold);
    margin-bottom: 1rem;
  }

  .past-event-images {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
    border-radius: 10px;
    overflow: hidden;
    margin-bottom: 1rem;
  }

  .img-placeholder {
    height: 140px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: rgba(255,255,255,0.7);
    border-radius: 8px;
  }

  .img-1 { background: linear-gradient(135deg, #1a1a2e, #f0b429aa); }
  .img-2 { background: linear-gradient(135deg, #2d1b00, #7a5c00); }
  .img-3 { background: linear-gradient(135deg, #0a1628, #1e3a5f); }
  .img-4 { background: linear-gradient(135deg, #1a0a2e, #4a1a6e); }
  .img-5 { background: linear-gradient(135deg, #0a2e0a, #1a5f1a); }
  .img-6 { background: linear-gradient(135deg, #2e0a0a, #6e1a1a); }

  .carousel-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(255,255,255,0.05);
    border: 1px solid #444;
    color: var(--text);
    width: 36px; height: 36px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
    z-index: 2;
  }
  .carousel-btn:hover { background: rgba(240,180,41,0.2); border-color: var(--gold); color: var(--gold); }
  .carousel-btn.prev { left: -18px; }
  .carousel-btn.next { right: -18px; }

  .carousel-dots {
    display: flex;
    gap: 0.5rem;
    justify-content: center;
    margin: 1rem 0;
  }

  .carousel-dots .dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: #444;
    cursor: pointer;
    transition: background 0.2s;
  }
  .carousel-dots .dot.active { background: var(--gold); }
</style>

<script>
  // Countdown
  const eventDate = new Date("2024-11-01T18:00:00");
  function updateCountdown() {
    const now = new Date();
    const diff = eventDate - now;
    if (diff <= 0) {
      document.getElementById("days").textContent = "00";
      document.getElementById("hours").textContent = "00";
      document.getElementById("minutes").textContent = "00";
      return;
    }
    const d = Math.floor(diff / 86400000);
    const h = Math.floor((diff % 86400000) / 3600000);
    const m = Math.floor((diff % 3600000) / 60000);
    document.getElementById("days").textContent = String(d).padStart(2,"0");
    document.getElementById("hours").textContent = String(h).padStart(2,"0");
    document.getElementById("minutes").textContent = String(m).padStart(2,"0");
  }
  updateCountdown();
  setInterval(updateCountdown, 60000);

  // Carousel
  const slides = document.querySelectorAll(".carousel-slide");
  const dotsContainer = document.getElementById("carouselDots");
  let current = 0;

  slides.forEach((_, i) => {
    const dot = document.createElement("button");
    dot.className = "dot" + (i === 0 ? " active" : "");
    dot.addEventListener("click", () => goTo(i));
    dotsContainer.appendChild(dot);
  });

  function goTo(idx) {
    slides[current].classList.remove("active");
    dotsContainer.children[current].classList.remove("active");
    current = (idx + slides.length) % slides.length;
    slides[current].classList.add("active");
    dotsContainer.children[current].classList.add("active");
  }

  document.getElementById("prevBtn").addEventListener("click", () => goTo(current - 1));
  document.getElementById("nextBtn").addEventListener("click", () => goTo(current + 1));
</script>
